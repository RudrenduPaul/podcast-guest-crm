# ============================================================
# Podcast Guest CRM — Web App Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and will never be committed.
#
# NEVER paste real keys into this file.
# This file is committed to version control as a template only.
# ============================================================

# API
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase (public — these are safe for the browser bundle)
# Get these from: https://app.supabase.com/ → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
