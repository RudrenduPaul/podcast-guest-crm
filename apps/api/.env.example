# ============================================================
# Podcast Guest CRM — API Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and will never be committed.
#
# NEVER paste real keys into this file.
# This file is committed to version control as a template only.
# ============================================================

# Server
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Anthropic (Claude AI)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Supabase
# Get these from: https://app.supabase.com/ → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# JWT
# Generate with: openssl rand -base64 32
JWT_SECRET=

# Resend (transactional email)
# Get your key at: https://resend.com/
RESEND_API_KEY=

# Database
# SQLite for local development — no setup required
DATABASE_URL=file:./dev.db
